{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/apps/web/Dockerfile",
    "watchPatterns": [
      "/apps/web/**",
      "/packages/ui/**",
      "/package.json",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json",
      "/turbo.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

