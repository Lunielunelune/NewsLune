{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "/services/enrichment-service/Dockerfile",
    "watchPatterns": [
      "/services/enrichment-service/**",
      "/packages/config/**",
      "/packages/contracts/**",
      "/packages/observability/**",
      "/packages/platform/**",
      "/package.json",
      "/pnpm-workspace.yaml",
      "/tsconfig.base.json",
      "/turbo.json"
    ]
  },
  "deploy": {
    "healthcheckPath": "/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}

